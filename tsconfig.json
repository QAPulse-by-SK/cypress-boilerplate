{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["cypress", "node"],
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["cypress/pages/*"],
      "@helpers/*": ["cypress/helpers/*"],
      "@constants/*": ["cypress/constants/*"],
      "@fixtures/*": ["cypress/fixtures/*"],
      "@support/*": ["cypress/support/*"],
      "@utils/*": ["cypress/utils/*"]
    }
  },
  "include": ["cypress/**/*.ts", "cypress.config.ts"],
  "exclude": ["node_modules"]
}
